# Sealship — Environment Variables
# Copy this file to .env and fill in the values

# ==========================================
# 1. GitHub Configuration
# REQUIRED for analyzing large repositories or dodging rate limits
# Create one at: https://github.com/settings/tokens
# ==========================================
GITHUB_TOKEN=your_github_personal_access_token_here

# ==========================================
# 2. AI Model Configuration (Generic OpenAI Compatible)
# Set PROVIDER to any supported: mistral, cerebras, openrouter, grok, openai
# ==========================================
LLM_PROVIDER=mistral
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-large-latest
LLM_MAX_TOKENS=2048

# ==========================================
# 3. IPFS Configuration (Pinata V3)
# Optional for local test, REQUIRED for production
# Get your JWT at: https://app.pinata.cloud/developers/api-keys
# Set MOCK_IPFS=true if you don't have a key yet
# ==========================================
PINATA_JWT=your_pinata_jwt_here
MOCK_IPFS=true
# Optional: custom Pinata gateway for faster retrieval
# NEXT_PUBLIC_GATEWAY_URL=your-gateway.mypinata.cloud

# ==========================================
# 4. Polkadot Hub Blockchain
# ==========================================
# Your MetaMask private key (DO NOT USE A MAINNET WALLET WITH REAL FUNDS)
POLKADOT_PRIVATE_KEY=your_wallet_private_key_here
POLKADOT_RPC_URL=https://eth-rpc-testnet.polkadot.io
NEXT_PUBLIC_CONTRACT_ADDRESS=0xafcdfc86e0f0076dbce64c0f034310b2efe79589

# ==========================================
# 5. Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/api
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================
# 6. Server Configuration
# ==========================================
# Frontend URL (for OpenRouter Referer and metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
